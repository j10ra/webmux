{
  "name": "webmux-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "A browser terminal backed by a persistent tmux session over WebSocket, with VSCode-grade UX.",
  "license": "MIT",
  "author": "Jetz Alipalo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint:style": "eslint .",
    "lint:style:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.5.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "fastify": "^4.29.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
