{
  "name": "@jalipalo/webmux-server",
  "version": "0.0.2",
  "description": "Fastify plugin: WebSocket terminal bridge backed by persistent tmux sessions (node-pty). The server side of webmux.",
  "license": "MIT",
  "author": "Jetz Alipalo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "fastify": "^4"
  },
  "dependencies": {
    "@fastify/websocket": "^10.0.1",
    "node-pty": "^1.1.0"
  },
  "keywords": [
    "terminal",
    "tmux",
    "node-pty",
    "fastify",
    "websocket",
    "pty"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j10ra/webmux.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/j10ra/webmux#readme",
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "fastify": "^4.29.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
